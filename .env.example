
# This was inserted by `prisma init`:

# Environment variables declared in this file are automatically made available to Prisma.

# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.

# See the documentation for all the connection string options: https://pris.ly/d/connection-strings
# Docker Compose: published API port on your machine only
PORT=3300
# Max JSON/body size (large Postman collection imports); default 50mb if unset
BODY_LIMIT=50mb

# Change this to a random string
SECRET="rahasia"

# GitHub OAuth (https://github.com/settings/developers → OAuth Apps)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Must match the app's "Authorization callback URL" (backend URL)
GITHUB_CALLBACK_URL=https://your.backend.url/auth/github/callback
# After GitHub OAuth: web uses /#fragment; Tauri uses zreq://oauth?query (fragment is often dropped by OS)
# Web: http://localhost:5173/   | Tauri: zreq://oauth
FRONTEND_OAUTH_URL=zreq://oauth

# MCP OAuth + SSE
# Must match the public origin used by agents (no trailing slash). In production: HTTPS full domain.
MCP_SERVER_URL=http://localhost:3300
MCP_RESOURCE=zreq-mcp
MCP_SERVER_NAME=zreq-mcp
MCP_SERVER_TITLE=ZReq MCP
MCP_SERVER_VERSION=0.1.0
# Keep empty to expose from root (e.g. /mcp/sse). Example custom prefix: /api
MCP_API_PREFIX=
# Streamable HTTP endpoint (recommended for Claude custom connector)
MCP_ENDPOINT=/mcp
# Optional SSE endpoints (only used if transport is SSE)
MCP_SSE_ENDPOINT=/mcp/sse
MCP_MESSAGES_ENDPOINT=/mcp/messages
MCP_OAUTH_AUTHORIZE_PATH=/mcp/oauth/authorize
MCP_OAUTH_CALLBACK_PATH=/mcp/oauth/callback
MCP_OAUTH_TOKEN_PATH=/mcp/oauth/token
MCP_OAUTH_REGISTER_PATH=/mcp/oauth/register
MCP_OAUTH_LOCAL_LOGIN_PATH=/mcp/oauth/local-login
# SECURITY: both must stay false in production (dev convenience only — requires explicit env opt-in)
MCP_ALLOW_DEFAULT_IDENTITY=false
MCP_ALLOW_EXTERNAL_IDENTITY_HINTS=false
# When true, only the user who created an OAuth client (via CRUD) can authorize with it.
# DCR clients (no owner) remain unrestricted. Default: false (standard OAuth model).
MCP_RESTRICT_CLIENT_TO_OWNER=false
# Production default: false to reduce refresh token attack surface
MCP_ENABLE_REFRESH_TOKENS=false
# Optional override; fallback to SECRET
# NOTE: MCP_JWT_SECRET must be >= 32 characters
MCP_JWT_SECRET=
# Optional pepper for hashing stored OAuth client secrets
MCP_OAUTH_SECRET_PEPPER=
# OAuth endpoint rate limits (per IP, per path, per window)
MCP_OAUTH_RATE_LIMIT_WINDOW_MS=60000
MCP_OAUTH_RATE_LIMIT_AUTHORIZE=60
MCP_OAUTH_RATE_LIMIT_REGISTER=20
MCP_OAUTH_RATE_LIMIT_TOKEN=30
MCP_OAUTH_RATE_LIMIT_LOCAL_LOGIN=10

# For Development
DATABASE_URL="mysql://root:@127.0.0.1:3306/database_name"