
# This was inserted by `prisma init`:

# Environment variables declared in this file are automatically made available to Prisma.

# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.

# See the documentation for all the connection string options: https://pris.ly/d/connection-strings
PORT=
# Max JSON/body size (large Postman collection imports); default 50mb if unset
BODY_LIMIT=

DATABASE_URL="mysql://root:@127.0.0.1:3306/database_name"

SECRET="rahasia"

# GitHub OAuth (https://github.com/settings/developers → OAuth Apps)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Must match the app's "Authorization callback URL" (backend URL)
GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback
# After GitHub OAuth: web uses /#fragment; Tauri uses zreq://oauth?query (fragment is often dropped by OS)
# Web: http://localhost:5173/   | Tauri: zreq://oauth
FRONTEND_OAUTH_URL=http://localhost:5173/
